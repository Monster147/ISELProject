{
  "expo": {
    "scheme": "InsuranceReporterApp",
    "name": "Insurance Reporter App",
    "slug": "IRA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../commons/img/adaptive_icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "../commons/img/adaptive_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#613089"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#613089",
        "foregroundImage": "../commons/img/adaptive_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "pt.isel.IRA"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ]
    ]
  }
}
