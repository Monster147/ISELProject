{
  "name": "frontend-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Unit tests (Jest) for the commons, desktop and movel frontend packages.",
  "scripts": {
    "test": "cross-env NODE_ENV=development jest",
    "test:commons": "cross-env NODE_ENV=development jest --selectProjects commons",
    "test:desktop": "cross-env NODE_ENV=development jest --selectProjects desktop",
    "test:movel": "cross-env NODE_ENV=development jest --selectProjects movel",
    "test:watch": "cross-env NODE_ENV=development jest --watch",
    "test:coverage": "cross-env NODE_ENV=development jest --coverage"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "babel-preset-expo": "~54.0.0",
    "expo": "~54.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expo": "~54.0.0",
    "cross-env": "^10.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
